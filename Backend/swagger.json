{
  "openapi": "3.0.0",
  "info": {
    "title": "Documentación API Tribe",
    "version": "1.0.0",
    "description": "API completa para la red social Tribe. Gestiona usuarios, colecciones multitemáticas y actividad social."
  },
  "servers": [
    {
      "url": "https://axel.informaticamajada.es",
      "description": "Servidor de Producción"
    },
    {
      "url": "http://localhost:3000",
      "description": "Servidor Local"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string", "example": "Mensaje descriptivo del error" }
        }
      },
      "Usuario": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "username": { "type": "string" },
          "email": { "type": "string" },
          "avatar_url": { "type": "string", "nullable": true },
          "bio": { "type": "string", "nullable": true }
        }
      }
    }
  },
  "tags": [
    { "name": "Auth", "description": "Gestión de sesiones y seguridad" },
    { "name": "Usuarios", "description": "Operaciones sobre perfiles y relaciones sociales" },
    { "name": "Colecciones", "description": "CRUD de colecciones e items" },
    { "name": "Búsqueda", "description": "Motores de búsqueda interna" },
    { "name": "Catálogo", "description": "Consulta de base de datos global (API externa/interna)" },
    { "name": "Actividad", "description": "Sistema de notificaciones" },
    { "name": "Admin", "description": "Panel de control y moderación" }
  ],
  "paths": {
    "/api/users/register": {
      "post": {
        "summary": "Registrar un nuevo usuario",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["username", "email", "password"],
                "properties": {
                  "username": { "type": "string", "example": "axel_dev" },
                  "email": { "type": "string", "example": "axel@example.com" },
                  "password": { "type": "string", "example": "password123" },
                  "g-recaptcha-response": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Usuario creado exitosamente" },
          "400": { "description": "Datos inválidos o Captcha faltante", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "409": { "description": "El nombre de usuario o email ya existe" }
        }
      }
    },
    "/api/users/login": {
      "post": {
        "summary": "Iniciar sesión",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "identifier": { "type": "string", "description": "Username o Email" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Login exitoso, devuelve token JWT" },
          "401": { "description": "Credenciales incorrectas" }
        }
      }
    },
    "/api/users/me": {
      "get": {
        "summary": "Obtener perfil propio",
        "description": "Retorna la información completa del usuario autenticado mediante el token.",
        "tags": ["Usuarios"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { 
            "description": "Perfil obtenido",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Usuario" } } }
          },
          "401": { "description": "Token inválido o expirado" }
        }
      }
    },
    "/api/collections/user/{userId}": {
      "get": {
        "summary": "Listar colecciones de un usuario",
        "tags": ["Colecciones"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "in": "path", "name": "userId", "required": true, "schema": { "type": "string" } },
          { "in": "query", "name": "sortBy", "schema": { "type": "string", "enum": ["recent", "oldest", "updated", "items"] }, "description": "Criterio de ordenación" },
          { "in": "query", "name": "order", "schema": { "type": "string", "enum": ["ASC", "DESC"], "default": "DESC" } }
        ],
        "responses": {
          "200": { "description": "Array de colecciones obtenido con éxito" },
          "401": { "description": "No autorizado" }
        }
      }
    },
    "/api/collections/{id}": {
      "get": {
        "summary": "Ver detalle y contenido de una colección",
        "description": "Retorna los datos de la colección y la lista de items (música, libros, etc.) que contiene.",
        "tags": ["Colecciones"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Objeto detallado de la colección e items" },
          "404": { "description": "Colección no encontrada" }
        }
      }
    },
    "/api/search/": {
      "get": {
        "summary": "Búsqueda global (Usuarios + Colecciones)",
        "tags": ["Búsqueda"],
        "parameters": [{ "in": "query", "name": "query", "schema": { "type": "string" }, "description": "Texto a buscar" }],
        "responses": {
          "200": { "description": "Resultados combinados de usuarios y colecciones" }
        }
      }
    },
    "/api/catalog/search": {
      "get": {
        "summary": "Búsqueda en el catálogo maestro",
        "tags": ["Catálogo"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "in": "query", "name": "query", "required": true, "schema": { "type": "string" } },
          { "in": "query", "name": "category", "schema": { "type": "string", "enum": ["General", "Music", "Books", "Movies", "Shows", "Games", "Custom"] } }
        ],
        "responses": {
          "200": { "description": "Resultados filtrados por categoría" },
          "400": { "description": "Categoría no válida" }
        }
      }
    },
    "/api/admin/data": {
      "get": {
        "summary": "Estadísticas globales para el administrador",
        "tags": ["Admin"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Conteos de usuarios, colecciones y reportes" },
          "403": { "description": "Acceso denegado (requiere rol admin)" }
        }
      }
    }
  }
}