{
  "openapi": "3.0.0",
  "info": {
    "title": "Documentación API Tribe",
    "version": "1.0.0",
    "description": "API del proyecto Tribe desarrollada en Node.js"
  },
  "servers": [
    {
      "url": "https://axel.informaticamajada.es",
      "description": "Servidor de Producción"
    },
    {
      "url": "http://localhost:3000",
      "description": "Servidor Local"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "tags": [
    { "name": "Auth", "description": "Autenticación y recuperación de contraseñas" },
    { "name": "Usuarios", "description": "Perfiles, seguidores y feed" },
    { "name": "Colecciones", "description": "Gestión, guardado y likes de colecciones" },
    { "name": "Búsqueda", "description": "Búsqueda de usuarios y colecciones" },
    { "name": "Catálogo", "description": "Catálogo global de items" },
    { "name": "Actividad", "description": "Notificaciones del usuario" },
    { "name": "Admin", "description": "Endpoints de administración" }
  ],
  "paths": {
    "/api/users/register": {
      "post": {
        "summary": "Registrar un nuevo usuario",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": { "type": "string" },
                  "email": { "type": "string" },
                  "password": { "type": "string" },
                  "g-recaptcha-response": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Usuario registrado" } }
      }
    },
    "/api/users/login": {
      "post": {
        "summary": "Iniciar sesión",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "identifier": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Login exitoso" } }
      }
    },
    "/api/users/google": {
      "post": {
        "summary": "Login con Google",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": { "token": { "type": "string" } }
              }
            }
          }
        },
        "responses": { "200": { "description": "Autenticación exitosa" } }
      }
    },
    "/api/users/forgot-password": {
      "post": {
        "summary": "Solicitar reseteo de contraseña",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": { "email": { "type": "string" } }
              }
            }
          }
        },
        "responses": { "200": { "description": "Solicitud enviada" } }
      }
    },
    "/api/users/reset-password": {
      "post": {
        "summary": "Resetear contraseña",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" },
                  "code": { "type": "string" },
                  "newPassword": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Contraseña actualizada" } }
      }
    },
    "/api/users/change-password": {
      "put": {
        "summary": "Cambiar contraseña (logueado)",
        "tags": ["Auth"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "currentPassword": { "type": "string" },
                  "newPassword": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Actualizada correctamente" } }
      }
    },
    "/api/users/me": {
      "get": {
        "summary": "Obtener perfil propio",
        "tags": ["Usuarios"],
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Perfil obtenido" } }
      }
    },
    "/api/users/feed/activity": {
      "get": {
        "summary": "Obtener feed de actividad",
        "tags": ["Usuarios"],
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Feed obtenido" } }
      }
    },
    "/api/users/complete-profile": {
      "put": {
        "summary": "Completar perfil (Onboarding)",
        "tags": ["Usuarios"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "userId": { "type": "string" },
                  "avatarUrl": { "type": "string" },
                  "interests": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Perfil completado" } }
      }
    },
    "/api/users/update-profile": {
      "put": {
        "summary": "Actualizar perfil",
        "tags": ["Usuarios"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "bio": { "type": "string" },
                  "avatarUrl": { "type": "string" },
                  "bannerUrl": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Perfil actualizado" } }
      }
    },
    "/api/users/follow/{id}": {
      "post": {
        "summary": "Seguir a un usuario",
        "tags": ["Usuarios"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Usuario seguido" } }
      }
    },
    "/api/users/unfollow/{id}": {
      "delete": {
        "summary": "Dejar de seguir",
        "tags": ["Usuarios"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Usuario dejado de seguir" } }
      }
    },
    "/api/users/followers/{id}": {
      "get": {
        "summary": "Ver seguidores",
        "tags": ["Usuarios"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Lista de seguidores" } }
      }
    },
    "/api/users/following/{id}": {
      "get": {
        "summary": "Ver seguidos",
        "tags": ["Usuarios"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Lista de seguidos" } }
      }
    },
    "/api/users/follow-stats/{id}": {
      "get": {
        "summary": "Estadísticas de seguimiento",
        "tags": ["Usuarios"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Stats obtenidas" } }
      }
    },
    "/api/users/{id}": {
      "get": {
        "summary": "Ver perfil público",
        "tags": ["Usuarios"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Perfil obtenido" } }
      }
    },
    "/api/collections/": {
      "post": {
        "summary": "Crear colección",
        "tags": ["Colecciones"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "collection_name": { "type": "string" },
                  "collection_type": { "type": "string" },
                  "collection_description": { "type": "string" },
                  "is_private": { "type": "boolean" },
                  "cover_url": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Colección creada" } }
      }
    },
    "/api/collections/{collection_id}/items": {
      "post": {
        "summary": "Añadir item",
        "tags": ["Colecciones"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "in": "path", "name": "collection_id", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "item_type": { "type": "string" },
                  "reference_id": { "type": "integer" },
                  "custom_title": { "type": "string" },
                  "custom_subtitle": { "type": "string" },
                  "custom_description": { "type": "string" },
                  "custom_image": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Item añadido" } }
      }
    },
    "/api/collections/{id}": {
      "get": {
        "summary": "Ver detalle de colección",
        "tags": ["Colecciones"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Colección obtenida" } }
      },
      "put": {
        "summary": "Actualizar colección",
        "tags": ["Colecciones"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "collection_name": { "type": "string" },
                  "collection_description": { "type": "string" },
                  "cover_url": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Actualizada" } }
      }
    },
    "/api/collections/save/{id}": {
      "post": {
        "summary": "Guardar en favoritos",
        "tags": ["Colecciones"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Guardada" } }
      }
    },
    "/api/collections/like/{id}": {
      "post": {
        "summary": "Dar o quitar like",
        "tags": ["Colecciones"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Toggle de like exitoso" } }
      }
    },
    "/api/collections/items/{itemId}": {
      "delete": {
        "summary": "Borrar item de colección",
        "tags": ["Colecciones"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "in": "path", "name": "itemId", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Item borrado" } }
      }
    },
    "/api/collections/{collection_id}": {
      "delete": {
        "summary": "Borrar colección",
        "tags": ["Colecciones"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "in": "path", "name": "collection_id", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Colección borrada" } }
      }
    },
    "/api/collections/saved/{id}": {
      "delete": {
        "summary": "Quitar de favoritos",
        "tags": ["Colecciones"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Quitada de favoritos" } }
      }
    },
    "/api/collections/user/{userId}": {
      "get": {
        "summary": "Colecciones del usuario",
        "tags": ["Colecciones"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "in": "path", "name": "userId", "required": true, "schema": { "type": "string" } },
          { "in": "query", "name": "sortBy", "schema": { "type": "string", "enum": ["recent", "oldest", "updated", "items"] } },
          { "in": "query", "name": "order", "schema": { "type": "string", "enum": ["ASC", "DESC"] } }
        ],
        "responses": { "200": { "description": "Lista obtenida" } }
      }
    },
    "/api/collections/saved/{userId}": {
      "get": {
        "summary": "Colecciones guardadas por el usuario",
        "tags": ["Colecciones"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "in": "path", "name": "userId", "required": true, "schema": { "type": "string" } },
          { "in": "query", "name": "sortBy", "schema": { "type": "string", "enum": ["recent", "updated", "items"] } },
          { "in": "query", "name": "order", "schema": { "type": "string", "enum": ["ASC", "DESC"] } }
        ],
        "responses": { "200": { "description": "Lista obtenida" } }
      }
    },
    "/api/search/": {
      "get": {
        "summary": "Búsqueda global",
        "tags": ["Búsqueda"],
        "parameters": [{ "in": "query", "name": "query", "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Resultados" } }
      }
    },
    "/api/search/suggested": {
      "get": {
        "summary": "Usuarios sugeridos",
        "tags": ["Búsqueda"],
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Lista de sugerencias" } }
      }
    },
    "/api/catalog/search": {
      "get": {
        "summary": "Buscar en catálogo",
        "tags": ["Catálogo"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "in": "query", "name": "query", "required": true, "schema": { "type": "string" } },
          { "in": "query", "name": "category", "schema": { "type": "string", "enum": ["General", "Music", "Books", "Movies", "Shows", "Games", "Custom"] } }
        ],
        "responses": { "200": { "description": "Catálogo obtenido" } }
      }
    },
    "/api/activity/": {
      "get": {
        "summary": "Obtener notificaciones",
        "tags": ["Actividad"],
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Notificaciones" } }
      }
    },
    "/api/activity/read-all": {
      "put": {
        "summary": "Marcar todas como leídas",
        "tags": ["Actividad"],
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Actualizado" } }
      }
    },
    "/api/activity/{id}/read": {
      "put": {
        "summary": "Marcar una como leída",
        "tags": ["Actividad"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Actualizado" } }
      }
    },
    "/api/admin/data": {
      "get": {
        "summary": "Datos del panel admin",
        "tags": ["Admin"],
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Datos obtenidos" } }
      }
    },
    "/api/admin/approve-reset": {
      "post": {
        "summary": "Aprobar reseteo",
        "tags": ["Admin"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": { "userId": { "type": "string" } }
              }
            }
          }
        },
        "responses": { "200": { "description": "Aprobado" } }
      }
    },
    "/api/admin/{type}/{id}": {
      "delete": {
        "summary": "Eliminar entidad",
        "tags": ["Admin"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "in": "path", "name": "type", "required": true, "schema": { "type": "string" } },
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Eliminado" } }
      }
    }
  }
}